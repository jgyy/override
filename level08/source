// level08 - Setuid Backup Utility
// Decompiled from binary analysis using objdump/strings
// 64-bit ELF, not stripped

#include <stdio.h>
#include <string.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>

// Write a log entry to the open log FILE:
//   fprintf(logfile, "%s: %s\n", tag, msg)
// The message is first strcpy'd into a local 256-byte buffer, then
// the remaining capacity is filled with snprintf (strncat semantics),
// and the newline is stripped with strcspn before fprintf.
void log_wrapper(FILE *logfile, const char *tag, const char *msg)
{
    char buf[256];
    strcpy(buf, msg);
    // append remaining space: snprintf(buf + strlen(buf), 0xfe - strlen(buf), "%s", extra)
    // (in practice the tag is the only extra arg, so this just appends nothing more)
    snprintf(buf + strlen(buf), 0xfe - strlen(buf), "%s", msg);
    buf[strcspn(buf, "\n")] = '\0';
    fprintf(logfile, "%s: %s\n", tag, buf);
}

int main(int argc, char **argv)
{
    FILE        *logfile;       // ./backups/.log
    FILE        *src;           // source: argv[1]
    int          dstfd;         // dest:   ./backups/<argv[1]>
    char         dstpath[100];  // "./backups/" + argv[1]
    char         byte;          // byte buffer for copy loop

    if (argc != 2)
        printf("Usage: %s filename\n", argv[0]);

    // Open log file for writing
    logfile = fopen("./backups/.log", "w");
    if (!logfile) {
        printf("ERROR: Failed to open %s\n", "./backups/.log");
        exit(1);
    }

    // Log the start of the backup
    log_wrapper(logfile, "Starting back up", argv[1]);

    // Open source file (argv[1]) for reading — no path sanitisation
    src = fopen(argv[1], "r");
    if (!src) {
        printf("ERROR: Failed to open %s\n", argv[1]);
        exit(1);
    }

    // Build destination path: "./backups/" + argv[1]
    strcpy(dstpath, "./backups/");
    strncat(dstpath, argv[1], 0x63 - strlen(dstpath));

    // Create destination file (fail if it already exists)
    dstfd = open(dstpath, O_WRONLY | O_CREAT | O_EXCL, 0660);
    if (dstfd < 0) {
        printf("ERROR: Failed to open %s%s\n", "./backups/", argv[1]);
        exit(1);
    }

    // Copy source -> destination byte by byte
    while ((byte = fgetc(src)) != (char)EOF) {
        write(dstfd, &byte, 1);
    }

    // Log completion and clean up
    log_wrapper(logfile, "Finished back up", argv[1]);
    fclose(src);
    close(dstfd);

    return 0;
}
